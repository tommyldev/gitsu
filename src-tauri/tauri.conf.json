{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gitsu",
  "version": "0.1.0",
  "identifier": "dev.gitsu.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gitsu",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/wt"],
    "category": "DeveloperTool",
    "shortDescription": "A worktree-first Git desktop client built on worktrunk",
    "longDescription": "gitsu is a Git desktop client where worktrees are the primary unit of organization. Built on top of worktrunk, it makes spawning, managing, and merging worktrees as easy as branches."
  }
}
